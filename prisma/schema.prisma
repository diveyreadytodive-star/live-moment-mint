generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Fixture {
  id           String   @id
  p1Id         String
  p2Id         String
  p1Name       String
  p2Name       String
  p1IsHome     Boolean
  p1Color      String   @default("#1a56db")
  p2Color      String   @default("#e02424")
  kickoffTs    Int
  // Live score fields — updated by keeper on every SSE event
  isLive       Boolean  @default(false)
  liveScoreP1  Int?
  liveScoreP2  Int?
  liveMinute   Int?
  statusId     Int?
  // Football-Data.org & TxLine cross-reference
  txlineId     String?  @unique  // TxLine FixtureId — set when TxLine has live coverage
  stage        String?           // GROUP_STAGE | LAST_16 | QUARTER_FINALS | SEMI_FINALS | THIRD_PLACE | FINAL

  moments     Moment[]
  predictions Prediction[]
}

model Moment {
  id            Int      @id @default(autoincrement())
  fixtureId     String
  kind          String   // GOAL | RESULT
  seq           Int
  tsEvent       Int
  teamScorerId  String?  // "1" | "2"
  goalType      String?  // "Head" | "Foot" | "Penalty" | "OwnGoal"
  minute        Int?
  scoreP1       Int      @default(0)
  scoreP2       Int      @default(0)
  imageUrl      String?
  metadataUrl   String?
  momentPda     String?
  onchainStatus String?  // null | 'OK' | 'FAILED'
  imageData     Bytes?   // PNG bytes, served via /api/moments/[id]/image
  metadataJson  String?  // JSON text, served via /api/moments/[id]/metadata
  status               String   @default("OPEN") // OPEN | CLOSED | VOID
  openTs               Int
  closeTs              Int
  isPredictionReward   Boolean  @default(false)
  predictionOutcome    String?  // HOME | DRAW | AWAY — which prediction unlocks this mint

  fixture       Fixture? @relation(fields: [fixtureId], references: [id])
  mints         Mint[]

  @@unique([fixtureId, seq, kind])
}

model Mint {
  id           Int    @id @default(autoincrement())
  momentId     Int
  minterPubkey String
  assetId      String
  txSig        String
  createdAt    Int

  moment       Moment @relation(fields: [momentId], references: [id])

  @@unique([txSig])                  // replay guard — same tx can't mint twice
  @@unique([momentId, minterPubkey]) // per-wallet per-moment guard
}

model Prediction {
  id        Int      @id @default(autoincrement())
  fixtureId String
  wallet    String
  outcome   String   // HOME | DRAW | AWAY
  createdAt Int

  fixture   Fixture  @relation(fields: [fixtureId], references: [id])

  @@unique([fixtureId, wallet])
}
